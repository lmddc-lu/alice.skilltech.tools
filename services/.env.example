# --- LLM / Embedding API (any OpenAI-compatible endpoint) ---
LLM_API_BASE=https://your-endpoint/v1
LLM_API_KEY=your-key
GENERATION_MODEL_ID=your-model
# Optional generation tuning; leave empty to use the app defaults
# (1.0 / 0.95 / 64 / true respectively).
LLM_TEMPERATURE=
LLM_TOP_P=
LLM_TOP_K=
LLM_ENABLE_THINKING=

# Embeddings. EMBED_API_BASE/KEY are the connection this service always uses
# (leave empty to fall back to the LLM endpoint above). EMBED_MODEL, EMBEDDING_DIM
# and the sparse settings below are the embedding *identity*: in normal operation
# the API pushes these per request and these env values are only a fallback for
# direct calls / standalone use. Keep them consistent with the API's EMBEDDING_*
# and SPARSE_EMBEDDING_MODEL settings. EMBED_MODEL default is qwen3-embedding:4b.
EMBED_API_BASE=
EMBED_API_KEY=
EMBED_MODEL=
# Dense vector size; must match the embedding model's output dimension.
EMBEDDING_DIM=2560

# Sparse / hybrid retrieval fallback (see note above). Empty model + false =
# dense only.
USE_SPARSE_EMBEDDINGS=false
SPARSE_EMBED_MODEL=prithvida/Splade_PP_en_v1

# --- Docling Serve (document conversion) ---
DOCLING_SERVE_URL=http://docling:5001
# DOCLING_SERVE_API_KEY=
DOCLING_SERVE_TIMEOUT=300
DOCLING_OCR_ENGINE=easyocr
DOCLING_OCR_LANG=en,fr,de
DOCLING_PDF_BACKEND=docling_parse
DOCLING_TABLE_MODE=accurate
DOCLING_DOCUMENT_TIMEOUT=240
# Decode detected formulas into LaTeX (adds an enrichment pass per formula).
# When false, docling emits "<!-- formula-not-decoded -->" placeholders.
DOCLING_DO_FORMULA_ENRICHMENT=false

# --- Session / Valkey ---
# REDIS_URL is kept for redis-py client compat; host points to the Valkey service
REDIS_URL=redis://valkey:6379/0
SESSION_TTL=3600
ENABLE_SESSION_STORAGE=true

# Rewrite referential follow-ups into standalone search queries before
# retrieval (resolves pronouns/ellipsis against recent turns). Adds one LLM
# call per turn that has history. Off by default.
CONTEXTUALIZE_QUERY_ENABLED=false

# --- PII filter ---
# PII_DEVICE: -1 for CPU, 0 for first GPU. GPU compose files default to 0,
# CPU compose files default to -1.
PII_MODEL_NAME=
PII_STRIDE=64
