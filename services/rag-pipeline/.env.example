# --- LLM / Embedding API (any OpenAI-compatible endpoint) ---
LLM_API_BASE=https://your-endpoint/v1
LLM_API_KEY=your-key
GENERATION_MODEL_ID=your-model
# Optional generation tuning; leave empty to use the app defaults
# (1.0 / 0.95 / 64 / true respectively).
LLM_TEMPERATURE=
LLM_TOP_P=
LLM_TOP_K=
LLM_ENABLE_THINKING=

# Embeddings. Leave empty to fall back to the LLM endpoint above.
# EMBED_MODEL default is qwen3-embedding:4b.
EMBED_API_BASE=
EMBED_API_KEY=
EMBED_MODEL=

# --- Docling Serve (document conversion) ---
DOCLING_SERVE_URL=http://docling:5001
# DOCLING_SERVE_API_KEY=
DOCLING_SERVE_CONCURRENCY=2
DOCLING_SERVE_TIMEOUT=300
DOCLING_OCR_ENGINE=easyocr
DOCLING_OCR_LANG=en,fr,de
DOCLING_PDF_BACKEND=docling_parse
DOCLING_TABLE_MODE=accurate
DOCLING_DOCUMENT_TIMEOUT=240

# --- Session / Redis ---
REDIS_URL=redis://redis:6379/0
SESSION_TTL=3600
ENABLE_SESSION_STORAGE=true
