# Project
PROJECT_NAME=alice
TAG=latest
DOCKER_IMAGE_API=alice_api
STACK_NAME=ALICE_STACK
ENVIRONMENT=local
FRONTEND_HOST=http://localhost:4200

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:4200,https://localhost,https://localhost:4200"
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme

# Postgres
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Haystack / RAG pipeline endpoints (the rag-pipeline service)
HAYSTACK_URL=http://172.17.0.1:1416
HAYSTACK_INFERENCE_URL=http://172.17.0.1:1416
HAYSTACK_INGESTION_URL=http://172.17.0.1:1417

# PII filter service (the services/pii-filter model service). Used by chatbots
# with the PII filter toggle enabled. Port matches services/docker-compose*.yml.
PII_FILTER_URL=http://172.17.0.1:1418

# OAuth / OIDC
OPENID_PROVIDER_URL=https://your-idp.example.com/.well-known/openid-configuration
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_SCOPES="openid email profile"
ENABLE_OAUTH_SIGNUP=true
OAUTH_MERGE_ACCOUNTS_BY_EMAIL=false

# Moodle integration SSRF allowlists. Both empty = only public IPs are reachable.
# MOODLE_ALLOWED_DOMAINS: hostnames whose DNS may resolve to a private IP.
# MOODLE_ALLOWED_NETWORKS: CIDRs that unblock literal-IP URLs (e.g. http://10.x.y.z)
#   AND unblock hostnames resolving to those IPs.
MOODLE_ALLOWED_DOMAINS=
MOODLE_ALLOWED_NETWORKS=

# Deployment-specific docker extra_hosts (host:ip pairs).
# Leave unset to fall back to non-resolvable .invalid placeholders.
EXTRA_HOST_1=
EXTRA_HOST_2=

# Job timeout settings
JOB_RUNNING_TIMEOUT_MINUTES=180
JOB_PENDING_TIMEOUT_MINUTES=240
HAYSTACK_STALE_TIMEOUT=3600
HAYSTACK_ABSOLUTE_TIMEOUT=86400

# S3 (Garage by default; any S3-compatible store works)
MINIO_URL=garage:3900
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET_NAME=alice
MINIO_REGION=garage

# RabbitMQ
RABBITMQ_DEFAULT_USER=alice
RABBITMQ_DEFAULT_PASS=changethis
RABBITMQ_URL=amqp://alice:changethis@rabbitmq:5672/
